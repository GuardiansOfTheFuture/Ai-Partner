# 阿里云百炼 API Key (必填)
# 获取地址: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-your-api-key-here

# 百炼模型配置
# LLM 模型: qwen-plus (推荐) / qwen-max / qwen-turbo
LLM_MODEL=qwen-plus
# Embedding 模型: text-embedding-v4 (推荐) / text-embedding-v3
EMBEDDING_MODEL=text-embedding-v4

# 向量数据库 (ChromaDB 持久化路径)
CHROMA_PERSIST_DIR=data/chroma_db

# 文件上传目录
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=20

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=multi_agent

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true
