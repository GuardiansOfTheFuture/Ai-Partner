<!-- 文档管理页 · 多巴胺风格 -->
<view class="page">

  <!-- 上传区域 -->
  <view class="upload-card card particle-bg">
    <view class="particle" style="width:18rpx;height:18rpx;background:var(--yellow);top:15%;left:20%;animation-delay:0s;"></view>
    <view class="particle" style="width:12rpx;height:12rpx;background:var(--mint);top:40%;right:25%;animation-delay:1.5s;"></view>

    <view class="upload-title">上传文档</view>
    <view class="upload-desc">支持 PDF · DOCX · TXT · Markdown</view>

    <view class="upload-btns">
      <button class="upload-btn pink-btn" bindtap="chooseFile">
        <text class="btn-icon">📂</text>
        <text>选择文件</text>
      </button>
    </view>

    <view wx:if="{{uploading}}" class="upload-progress">
      <view class="progress-bar">
        <view class="progress-fill"></view>
      </view>
      <text class="progress-text">上传处理中...</text>
    </view>
  </view>

  <!-- 文档列表 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">已上传文档</text>
      <text class="card-count">{{documents.length}} 个</text>
    </view>

    <block wx:if="{{documents.length > 0}}">
      <view class="doc-item" wx:for="{{documents}}" wx:key="document_id">
        <view class="doc-info">
          <view class="doc-name">{{item.file_name}}</view>
          <view class="doc-meta">
            <text class="tag tag-pink">{{item.file_type}}</text>
            <text class="tag tag-mint">{{item.chunk_count}} 块</text>
          </view>
        </view>
        <view class="doc-status {{item.status}}">{{item.status}}</view>
        <view class="doc-delete" bindtap="deleteDoc" data-id="{{item.document_id}}">
          <text>×</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty-docs">
      <text class="empty-icon">📭</text>
      <text>还没有上传文档</text>
    </view>
  </view>

</view>
