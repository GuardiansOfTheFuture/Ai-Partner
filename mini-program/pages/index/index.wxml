<!-- 小暖 · 首页 -->
<view class="page">

  <view class="hero particle-bg">
    <!-- 浮动粒子 -->
    <view class="particle" style="width:20rpx;height:20rpx;background:var(--yellow);top:10%;left:15%;animation-delay:0s;"></view>
    <view class="particle" style="width:14rpx;height:14rpx;background:var(--mint);top:30%;left:80%;animation-delay:1s;"></view>
    <view class="particle" style="width:24rpx;height:24rpx;background:var(--purple);top:60%;left:10%;animation-delay:2s;"></view>
    <view class="particle" style="width:16rpx;height:16rpx;background:var(--sky);top:20%;left:50%;animation-delay:3s;"></view>
    <view class="particle" style="width:12rpx;height:12rpx;background:var(--pink);top:70%;left:70%;animation-delay:1.5s;"></view>

    <view class="hero-avatar">🌸</view>
    <view class="hero-title gradient-text">小暖</view>
    <view class="hero-subtitle">你的 AI 女友 · 随时陪你聊聊天</view>

    <view class="status-chip {{backendOnline ? 'online' : 'offline'}}" bindtap="checkHealth">
      <view class="status-dot"></view>
      {{backendOnline ? '小暖在线' : '小暖睡着了...'}}
    </view>
  </view>

  <!-- 开始聊天 -->
  <view class="card" style="text-align:center;">
    <button class="chat-btn" bindtap="goChat">
      <text>和她聊聊 💕</text>
    </button>
  </view>

</view>
